# Econmesh API (apps/web dev server runs on port 3001 — see apps/web/package.json)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Firebase Auth — projeto de AUTENTICAÇÃO (Console → Project settings → Your apps → Web)
# Upload de imagens é feito via API (presigned URL); não precisa do SDK Storage no browser.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=


# Session cookie (server)
SESSION_SECRET=change-me-in-production-min-32-chars

# Canonical app URL for Firebase email links (must match Authorized domains in Firebase Console)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
